{
  "name": "neighborhood-incident-report",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "^1.4.18",
      "@orpc/client": "^1.12.2",
      "@better-auth/expo": "^1.4.18",
      "@prisma/client": "^7.2.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @neighborhood-incident-report/db db:push",
    "db:studio": "turbo -F @neighborhood-incident-report/db db:studio",
    "db:generate": "turbo -F @neighborhood-incident-report/db db:generate",
    "db:migrate": "turbo -F @neighborhood-incident-report/db db:migrate",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@neighborhood-incident-report/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@neighborhood-incident-report/config": "workspace:*",
    "@types/node": "^22.13.14",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
