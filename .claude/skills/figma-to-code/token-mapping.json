{
  "version": "1.0.0",
  "description": "Figma variable → app-* token mapping for new-ticket-app",
  "mappings": {
    "color/text/primary": "app-text",
    "color/text/default": "app-text",
    "color/text/secondary": "app-text-sub",
    "color/text/sub": "app-text-sub",
    "color/text/tertiary": "app-text-muted",
    "color/text/muted": "app-text-muted",
    "color/text/placeholder": "app-text-placeholder",
    "color/link": "app-link",
    "color/link/default": "app-link",
    "color/accent/primary": "app-accent",
    "color/accent/default": "app-accent",
    "color/accent/blue": "app-accent",
    "color/accent/pink": "app-accent-pink",
    "color/accent/gold": "app-accent-gold",
    "color/icon/primary": "app-icon",
    "color/icon/default": "app-icon",
    "color/icon/muted": "app-icon-muted",
    "color/bg/surface": "app-surface",
    "color/bg/input": "app-surface",
    "color/bg/page": "app-surface-page",
    "color/bg/search": "app-surface-search",
    "color/bg/muted": "app-surface-muted",
    "color/border/primary": "app-border",
    "color/border/default": "app-border",
    "color/border/light": "app-border-light",
    "color/badge/blue/bg": "app-badge-blue-bg",
    "color/badge/blue/text": "app-badge-blue-text",
    "color/badge/yellow/bg": "app-badge-yellow-bg",
    "color/badge/yellow/text": "app-badge-yellow-text",
    "color/gradient/from": "app-gradient-from",
    "color/gradient/via": "app-gradient-via",
    "color/gradient/to": "app-gradient-to"
  },
  "colorValueMappings": {
    "#231916": "app-text",
    "#919191": "app-text-sub",
    "#555555": "app-text-muted",
    "#a7a3a2": "app-text-placeholder",
    "#5ab9ff": "app-link",
    "#3c6bff": "app-accent",
    "#f19ec2": "app-accent-pink",
    "#f9bb00": "app-accent-gold",
    "#5eacee": "app-icon",
    "#a7a5a8": "app-icon-muted",
    "#f7f7f7": "app-surface",
    "#f3f3f4": "app-surface-page",
    "#f5f7fa": "app-surface-search",
    "#efefef": "app-surface-muted",
    "#d8dde5": "app-border",
    "#edf2f7": "app-border-light",
    "#e8f0fe": "app-badge-blue-bg",
    "#d48806": "app-badge-yellow-text",
    "#fef3e2": "app-badge-yellow-bg",
    "#e162bd": "app-gradient-from",
    "#ff4d8e": "app-gradient-via"
  },
  "fallbackStrategy": {
    "unmappedColors": "suggest",
    "shadcnDefault": true,
    "comments": "When Figma variable not found, suggest new app-* token or use shadcn default colors (e.g., text-gray-600, bg-gray-100)"
  },
  "notes": {
    "tokenPrefix": "app-*",
    "prohibitedPrefixes": ["td-", "ticketdive-"],
    "tailwindUsage": "text-app-text, bg-app-surface, border-app-border",
    "referenceFiles": [
      "apps/admin/src/app/globals.css",
      "apps/admin/src/styles/themes/ticketdive.css"
    ]
  }
}
